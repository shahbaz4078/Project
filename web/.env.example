# Copy to .env — Vite exposes only vars prefixed with VITE_
# Dev: leave VITE_API_URL empty so Vite proxies /api -> backend :4000 (vite.config.js)
# Do NOT point at the wrong port — wrong URL causes "Network Error" on register/login
VITE_API_URL=
# Direct to API (optional): VITE_API_URL=http://localhost:4000/api/v1
# Socket.IO must reach the Node server (not the Vite port)
VITE_SOCKET_URL=http://localhost:4000
