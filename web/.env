# AgriSupplyChain API (Express on port 4000)
# Leave VITE_API_URL empty so Vite proxies /api -> http://localhost:4000 (see vite.config.js)
# VITE_API_URL=
# Or call API directly (then CORS on backend must allow http://localhost:5173):
VITE_API_URL=https://project-3-fhay.onrender.com/api/v1

VITE_SOCKET_URL=https://project-3-fhay.onrender.com

# Optional — wagmi / demo contract (not used by REST auth)
VITE_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
VITE_CHAIN_ID=80001
