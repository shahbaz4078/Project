NODE_ENV=development
PORT=4000
# --- MongoDB (required) ---
# Local (Docker): docker compose -f docker-compose.mongodb.yml up -d
# Local (native install): ensure mongod is listening on 27017
MONGODB_URI=mongodb://127.0.0.1:27017/agrisupply
# Atlas example (use your user, password, cluster host; URL-encode special chars in password):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/agrisupply?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Comma-separated — include Vite dev server (5173) for Socket.IO from the browser
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Ethereum — optional; leave empty to run API without on-chain writes
CHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CHAIN_ID=11155111
SHIPMENT_AUDIT_CONTRACT=
# Hex private key for server wallet (testnet only — use KMS/HSM in production)
ETH_PRIVATE_KEY=
